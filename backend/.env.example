PORT=3000

# OneSignal (use REST API Key from dashboard: Keys & IDs → API keys)
ONESIGNAL_APP_ID=your_app_id
ONESIGNAL_API_KEY=your_rest_api_key
# Optional override (default is https://api.onesignal.com/notifications)
# ONESIGNAL_API_URL=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=notifications_demo

# TLS for hosted Postgres (Neon, Supabase, Railway, etc.). Omit or false for local Postgres.
# DB_SSL=true
# If the server uses a certificate Node does not trust, set to false (less strict).
# DB_SSL_REJECT_UNAUTHORIZED=false

# Optional: path to OpenAPI YAML for /api-docs (default: ./openapi.yaml next to package.json)
# OPENAPI_SPEC_PATH=

# Security
API_KEY=super_secure_key
